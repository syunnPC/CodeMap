<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CodeMap.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CodeMap">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="WorkspaceSplitDividerTrackBrush" Color="#12FFFFFF" />
                    <SolidColorBrush x:Key="WorkspaceSplitDividerStrokeBrush" Color="#66FFFFFF" />
                    <SolidColorBrush x:Key="GraphRecoveryOverlayBrush" Color="#CC1E2126" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="WorkspaceSplitDividerTrackBrush" Color="#10000000" />
                    <SolidColorBrush x:Key="WorkspaceSplitDividerStrokeBrush" Color="#64000000" />
                    <SolidColorBrush x:Key="GraphRecoveryOverlayBrush" Color="#CCF5F7FA" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WorkspaceSplitDividerTrackBrush" Color="#12FFFFFF" />
                    <SolidColorBrush x:Key="WorkspaceSplitDividerStrokeBrush" Color="#66FFFFFF" />
                    <SolidColorBrush x:Key="GraphRecoveryOverlayBrush" Color="#CC1E2126" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
