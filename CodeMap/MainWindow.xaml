<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CodeMap.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:CodeMap.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:CodeMap.ViewModels"
    mc:Ignorable="d"
    Title="CodeMap">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootLayout"
        KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator
                Key="Enter"
                Modifiers="Control"
                Invoked="OnAnalyzeKeyboardAcceleratorInvoked" />
            <KeyboardAccelerator
                Key="F"
                Modifiers="Control"
                Invoked="OnFocusExplorerSearchKeyboardAcceleratorInvoked" />
            <KeyboardAccelerator
                Key="L"
                Modifiers="Control"
                Invoked="OnFocusWorkspacePathKeyboardAcceleratorInvoked" />
            <KeyboardAccelerator
                Key="R"
                Modifiers="Control,Shift"
                Invoked="OnLoadCacheKeyboardAcceleratorInvoked" />
            <KeyboardAccelerator
                Key="Left"
                Modifiers="Menu"
                Invoked="OnNavigateBackKeyboardAcceleratorInvoked" />
            <KeyboardAccelerator
                Key="Right"
                Modifiers="Menu"
                Invoked="OnNavigateForwardKeyboardAcceleratorInvoked" />
        </Grid.KeyboardAccelerators>

        <Grid.ChildrenTransitions>
            <EntranceThemeTransition FromVerticalOffset="40" />
        </Grid.ChildrenTransitions>

        <!-- Row 0: Custom Title Bar -->
        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Height="48"
            Margin="0"
            VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image
                Grid.Column="0"
                Width="16"
                Height="16"
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Source="ms-appx:///Assets/StoreLogo.png" />

            <TextBlock
                Grid.Column="1"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="CodeMap">
                <TextBlock.Foreground>
                    <SolidColorBrush Color="{ThemeResource TextFillColorPrimary}" />
                </TextBlock.Foreground>
            </TextBlock>
        </Grid>

        <!-- Row 1: Workspace Toolbar -->
        <Grid
            Grid.Row="1"
            Margin="16,4,16,0"
            Padding="6"
            ColumnSpacing="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="SolutionPathTextBox"
                VerticalAlignment="Center"
                AccessKey="W"
                AutomationProperties.Name="Workspace path input"
                HorizontalAlignment="Stretch" />

            <ComboBox
                x:Name="BrowseSolutionComboBox"
                Grid.Column="1"
                AccessKey="B"
                PlaceholderText="最近のワークスペース"
                AutomationProperties.Name="Recent workspace selector"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"
                SelectionChanged="OnBrowseSolutionSelectionChanged" />

            <Button
                x:Name="LoadCacheButton"
                Grid.Column="2"
                AccessKey="R"
                AutomationProperties.Name="Load cached snapshot"
                VerticalAlignment="Center"
                Click="OnLoadCachedSnapshotClicked"
                ToolTipService.Placement="Bottom">
                <ToolTipService.ToolTip>
                    <ToolTip>
                        <StackPanel MaxWidth="280" Spacing="4">
                            <TextBlock
                                x:Name="LoadCacheTooltipLine1TextBlock"
                                Text="現在のワークスペースに保存されている最新の解析結果を読み込みます。"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                x:Name="LoadCacheTooltipLine2TextBlock"
                                Text="すぐに構造を確認したいときに使います。コードを更新した後は「解析」で作り直してください。"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </ToolTip>
                </ToolTipService.ToolTip>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Grid Width="16" Height="16">
                        <FontIcon
                            x:Name="LoadCacheButtonIcon"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Glyph="&#xE823;"
                            FontSize="14" />
                        <ProgressRing
                            x:Name="LoadCacheButtonProgressRing"
                            Width="14"
                            Height="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsActive="False"
                            Visibility="Collapsed" />
                    </Grid>
                    <TextBlock
                        x:Name="LoadCacheButtonTextBlock"
                        Text="前回結果" />
                </StackPanel>
            </Button>

            <Button
                x:Name="AnalyzeButton"
                Grid.Column="3"
                AccessKey="A"
                AutomationProperties.Name="Analyze workspace"
                VerticalAlignment="Center"
                Style="{StaticResource AccentButtonStyle}"
                Click="OnAnalyzeClicked"
                ToolTipService.ToolTip="ワークスペースの解析を開始">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Grid Width="16" Height="16">
                        <FontIcon
                            x:Name="AnalyzeButtonIcon"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Glyph="&#xE768;"
                            FontSize="14" />
                        <ProgressRing
                            x:Name="AnalyzeButtonProgressRing"
                            Width="14"
                            Height="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                            IsActive="False"
                            Visibility="Collapsed" />
                    </Grid>
                    <TextBlock
                        x:Name="AnalyzeButtonTextBlock"
                        Text="解析" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Row 2: Main Content (Explorer + Graph) -->
        <Grid
            x:Name="MainContentGrid"
            Grid.Row="2"
            Margin="16,12,16,0"
            ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    x:Name="ExplorerPanelColumn"
                    Width="300"
                    MinWidth="240" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Explorer Panel (Tree + Symbols) -->
            <Grid
                Grid.Column="0"
                Margin="0,0,6,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Explorer Header: Tab selector + Split toggle -->
                <Grid
                    Grid.Row="0"
                    Padding="8,6,8,2"
                    ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        x:Name="WorkspaceTabSelector"
                        Orientation="Horizontal"
                        Spacing="2">
                        <ToggleButton
                            x:Name="TreeTabButton"
                            AutomationProperties.Name="Tree tab"
                            IsChecked="True"
                            Click="OnWorkspaceTabChanged"
                            Padding="10,5"
                            MinWidth="0"
                            MinHeight="0"
                            CornerRadius="4">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE8B7;" FontSize="12" />
                                <TextBlock
                                    x:Name="TreeTabTextBlock"
                                    Text="ツリー"
                                    FontSize="12" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton
                            x:Name="SymbolTabButton"
                            AutomationProperties.Name="Symbol tab"
                            Click="OnWorkspaceTabChanged"
                            Padding="10,5"
                            MinWidth="0"
                            MinHeight="0"
                            CornerRadius="4">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon Glyph="&#xE943;" FontSize="12" />
                                <TextBlock
                                    x:Name="SymbolTabTextBlock"
                                    Text="シンボル"
                                    FontSize="12" />
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>

                    <ToggleButton
                        x:Name="SplitToggleButton"
                        Grid.Column="1"
                        AutomationProperties.Name="Toggle split view"
                        Click="OnSplitToggleClicked"
                        Padding="6"
                        MinWidth="0"
                        MinHeight="0"
                        CornerRadius="4"
                        ToolTipService.ToolTip="分割表示の切り替え">
                        <FontIcon Glyph="&#xE8A4;" FontSize="12" />
                    </ToggleButton>
                </Grid>

                <StackPanel
                    Grid.Row="1"
                    Padding="8,0,8,6"
                    Spacing="4">
                    <TextBox
                        x:Name="ExplorerSearchTextBox"
                        AccessKey="F"
                        AutomationProperties.Name="Explorer search"
                        TextChanged="OnExplorerSearchTextChanged" />
                    <TextBlock
                        x:Name="ExplorerSearchSummaryTextBlock"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="プロジェクト 0 / ファイル 0 / シンボル 0" />
                </StackPanel>

                <!-- Explorer Content: Tree and Symbols with togglable layout -->
                <Grid x:Name="ExplorerContentGrid" Grid.Row="2" Padding="6,0,6,6">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="TreeContentRow" Height="*" />
                        <RowDefinition x:Name="WorkspaceSplitRow" Height="0" />
                        <RowDefinition x:Name="SymbolContentRow" Height="0" />
                    </Grid.RowDefinitions>

                    <TreeView
                        x:Name="WorkspaceTreeView"
                        Grid.Row="0"
                        AutomationProperties.Name="Workspace tree"
                        FontFamily="Segoe UI Variable Text"
                        SelectionChanged="OnWorkspaceTreeSelectionChanged"
                        ItemInvoked="OnWorkspaceTreeItemInvoked"
                        Padding="0,0,0,4" />

                    <controls:CursorGrid
                        x:Name="WorkspaceSplitDivider"
                        Grid.Row="1"
                        AutomationProperties.Name="Workspace split divider"
                        CursorShape="SizeNorthSouth"
                        Height="14"
                        Margin="0,3"
                        Background="Transparent"
                        Visibility="Collapsed"
                        PointerPressed="OnWorkspaceSplitDividerPointerPressed"
                        PointerMoved="OnWorkspaceSplitDividerPointerMoved"
                        PointerReleased="OnWorkspaceSplitDividerPointerReleased"
                        PointerCaptureLost="OnWorkspaceSplitDividerPointerCaptureLost">
                        <Border
                            CornerRadius="999"
                            Background="{ThemeResource WorkspaceSplitDividerTrackBrush}" />
                        <Border
                            Height="1"
                            Margin="10,0"
                            VerticalAlignment="Center"
                            Background="{ThemeResource WorkspaceSplitDividerStrokeBrush}" />
                    </controls:CursorGrid>

                    <ListView
                        x:Name="SymbolsListView"
                        Grid.Row="2"
                        AutomationProperties.Name="Symbol list"
                        FontFamily="Segoe UI Variable Text"
                        Padding="0,4,0,0"
                        SelectionChanged="OnSymbolsListViewSelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:SymbolListItem">
                                <Grid Padding="4,6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <FontIcon
                                        Glyph="{x:Bind IconGlyph}"
                                        FontSize="12"
                                        Foreground="{ThemeResource AccentTextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="1" Spacing="1">
                                        <TextBlock
                                            Text="{x:Bind DisplayText}"
                                            FontSize="13"
                                            TextWrapping="NoWrap"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{x:Bind DisplayText}" />
                                        <TextBlock
                                            Text="{x:Bind DetailText}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            TextWrapping="NoWrap"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{x:Bind DetailText}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border
                        x:Name="ExplorerEmptyStateOverlay"
                        Grid.RowSpan="3"
                        Padding="18"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        CornerRadius="6"
                        Visibility="Visible"
                        IsHitTestVisible="False">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="320"
                            Spacing="8">
                            <FontIcon
                                Glyph="&#xE8A5;"
                                FontSize="24"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                x:Name="ExplorerEmptyStateTitleTextBlock"
                                Text="ワークスペースを開いてください"
                                HorizontalAlignment="Center"
                                FontWeight="SemiBold"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                x:Name="ExplorerEmptyStateDescriptionTextBlock"
                                Text="上部の入力欄にパスを指定し、解析または前回結果を実行してください。"
                                HorizontalAlignment="Center"
                                TextAlignment="Center"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <controls:CursorGrid
                x:Name="ExplorerPanelSplitDivider"
                Grid.Column="1"
                AutomationProperties.Name="Explorer panel divider"
                CursorShape="SizeWestEast"
                Width="12"
                Margin="0,8"
                Background="Transparent"
                PointerPressed="OnExplorerPanelSplitDividerPointerPressed"
                PointerMoved="OnExplorerPanelSplitDividerPointerMoved"
                PointerReleased="OnExplorerPanelSplitDividerPointerReleased"
                PointerCaptureLost="OnExplorerPanelSplitDividerPointerCaptureLost">
                <Border
                    Width="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Background="{ThemeResource WorkspaceSplitDividerStrokeBrush}" />
            </controls:CursorGrid>

            <!-- Right: Graph -->
            <Border
                Grid.Column="2"
                x:Name="GraphPanelBorder"
                Margin="6,0,0,0"
                MinHeight="360"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Padding="0">
                <Grid
                    x:Name="GraphPanelClipHost">
                    <WebView2
                        x:Name="GraphWebView"
                        AutomationProperties.Name="Dependency graph"
                        MinHeight="360"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />
                    <Border
                        x:Name="GraphEmptyStateOverlay"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Visibility="Visible"
                        IsHitTestVisible="False">
                        <Grid
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="360"
                                Spacing="10">
                                <FontIcon
                                    Glyph="&#xE8A5;"
                                    FontSize="26"
                                    HorizontalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    x:Name="GraphEmptyStateTitleTextBlock"
                                    Text="グラフを表示する準備ができていません"
                                    HorizontalAlignment="Center"
                                    TextAlignment="Center"
                                    FontWeight="SemiBold"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    x:Name="GraphEmptyStateDescriptionTextBlock"
                                    Text="ワークスペースを読み込むと、依存関係グラフがここに表示されます。"
                                    HorizontalAlignment="Center"
                                    TextAlignment="Center"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border
                        x:Name="GraphRecoveryOverlay"
                        Background="{ThemeResource GraphRecoveryOverlayBrush}"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Visibility="Collapsed">
                        <Grid
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10">
                                <ProgressRing
                                    x:Name="GraphRecoveryProgressRing"
                                    Width="28"
                                    Height="28"
                                    IsActive="False" />
                                <TextBlock
                                    x:Name="GraphRecoveryTextBlock"
                                    HorizontalAlignment="Center"
                                    TextAlignment="Center"
                                    Text="グラフを復旧しています..."
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 3: Status Bar -->
        <Grid
            Grid.Row="3"
            Margin="16,8,16,12"
            Padding="12,6"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon
                x:Name="StatusIcon"
                Glyph="&#xE73E;"
                FontSize="12"
                VerticalAlignment="Center"
                Foreground="{ThemeResource SystemFillColorSuccessBrush}" />

            <TextBlock
                x:Name="StatusTextBlock"
                Grid.Column="1"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="準備完了" />

            <Button
                x:Name="ShowDiagnosticsButton"
                Grid.Column="2"
                AccessKey="D"
                AutomationProperties.Name="Show diagnostics"
                Padding="6,4"
                MinWidth="0"
                MinHeight="0"
                VerticalAlignment="Center"
                Click="OnShowDiagnosticsClicked"
                ToolTipService.ToolTip="診断ログを表示"
                Background="Transparent"
                BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xEBE8;" FontSize="11" />
                    <TextBlock
                        x:Name="DiagnosticsButtonTextBlock"
                        Text="ログ"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Button>

            <Button
                x:Name="ShowSettingsButton"
                Grid.Column="3"
                AccessKey="S"
                AutomationProperties.Name="Show settings"
                Margin="6,0,0,0"
                Padding="6,4"
                MinWidth="0"
                MinHeight="0"
                VerticalAlignment="Center"
                Click="OnShowSettingsClicked"
                ToolTipService.ToolTip="設定とバージョン情報を表示"
                Background="Transparent"
                BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE713;" FontSize="11" />
                    <TextBlock
                        x:Name="SettingsButtonTextBlock"
                        Text="設定"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
